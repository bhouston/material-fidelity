{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "ignorePatterns": ["third_party/**"],
  "plugins": ["eslint", "typescript", "oxc", "unicorn", "vitest"],
  "rules": {
    "eslint/no-underscore-dangle": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.spec.ts"],
      "plugins": ["eslint", "typescript", "oxc", "unicorn", "vitest"]
    }
  ]
}

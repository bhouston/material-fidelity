{
  "name": "materialx-fidelity",
  "version": "0.1.0",
  "private": true,
  "description": "MaterialX fidelity test system for reference image generation and comparison workflows.",
  "keywords": [
    "materialx",
    "rendering",
    "fidelity",
    "testing"
  ],
  "license": "MIT",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "tsgo -b && pnpm -r --if-present build",
    "dev": "pnpm -r --parallel --stream dev",
    "clean": "rimraf dist packages/**/dist adapters/**/dist",
    "clean:all": "pnpm clean && rimraf node_modules packages/**/node_modules adapters/**/node_modules",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "tsc": "tsgo -b",
    "tsgo": "tsgo -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cli": "pnpm --filter @materialx-fidelity/cli start",
    "viewer": "pnpm --filter @materialx-fidelity/viewer dev",
    "viewer:build": "pnpm --filter @materialx-fidelity/viewer build"
  },
  "dependencies": {
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "^7.0.0-dev.20260421.1",
    "@vitest/coverage-v8": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
